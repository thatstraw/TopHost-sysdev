{
	"manifest_version": 2.0,
	"id": "tophostssysdev",
	"type": "widget",
	"name": "Top hosts Sysdev",
	"namespace": "TopHostsSysdev",
	"version": "2.0",
	"author": "Sysdev",
	"description": "Displays top N hosts that have the highest or the lowest item value (for example, CPU load) with an option to add progress-bar visualizations and customize report columns.",
	"widget": {
		"js_class": "CWidgetTopHostsSysdev",
		"in": {
			"hostids": {
				"type": "_hostids"
			},
			"groupids": {
				"type": "_hostgroupids"
			}
		},
		"out": [
			{
				"type": "_hostid"
			},
			{
				"type": "_hostids"
			}
		]
	},
	"actions": {
		"widget.tophostssysdev.view": {
			"class": "WidgetViewSysdev"
		},
		"widget.tophostssysdev.column.edit": {
			"class": "ColumnEditSysdev",
			"view": "column.edit",
			"layout": "layout.json"
		}
	},
	"assets": {
		"js": ["class.widgetsysdev.js"],
		"css": ["widget.sysdev.css"]
	}
}
